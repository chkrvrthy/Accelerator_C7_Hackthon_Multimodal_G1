# =============================================================================
# Multimodal AI Design Analysis Suite — environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# --- OpenRouter (single key, many models) -----------------------------------
# Sprint 1: OpenAI Chat Completion standard. We use the openai SDK pointed at
# OpenRouter so one key unlocks GPT-4o, Claude, Gemini, Llama, etc.
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional headers OpenRouter recommends for analytics / rate-limit tiers.
OPENROUTER_APP_NAME=design-analysis-suite
OPENROUTER_SITE_URL=https://example.com

# --- Default models ---------------------------------------------------------
# Pick any vision-capable OpenRouter model id. Examples:
#   openai/gpt-4o, openai/gpt-4o-mini, anthropic/claude-3.5-sonnet,
#   google/gemini-2.0-flash-exp, meta-llama/llama-3.2-90b-vision-instruct.
DEFAULT_VISION_MODEL=openai/gpt-4o-mini
DEFAULT_TEXT_MODEL=openai/gpt-4o-mini
DEFAULT_TEMPERATURE=0.2
DEFAULT_MAX_TOKENS=2048

# --- Web search (Market Research agent) -------------------------------------
# Tavily returns LLM-friendly snippets. DuckDuckGo is the no-key fallback.
TAVILY_API_KEY=

# --- Image RAG (Sprint 3: chunking, CLIP, LanceDB, LlamaIndex) -------------
# LanceDB is an embedded vector DB; the URI is just a filesystem path.
VECTOR_STORE_DIR=./data/vector_store
VECTOR_COLLECTION=design_references

# CLIP embedding model — used for both image and short-text queries so
# image-image and text-image retrieval share one vector space.
CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k

# --- Storage paths ----------------------------------------------------------
UPLOAD_DIR=./data/uploads
REFERENCE_DIR=./data/reference
REPORT_DIR=./data/reports
CACHE_DIR=./data/cache

# --- LangSmith tracing (Sprint 5, optional) ---------------------------------
# When enabled, every LangGraph node shows up as a span in the LangSmith UI.
# Leave blank to fall back to local logs gracefully.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=design-analysis-suite

# --- MCP server (Sprint 4) --------------------------------------------------
# Stdio mode is the default; flip to "http" only after you wire a transport.
MCP_TRANSPORT=stdio

# --- Cost optimization (Sprint 5) -------------------------------------------
# Set to 1 to bypass the response cache (used by `make eval` so the eval
# harness measures real LLM behavior, not cached replays).
CACHE_DISABLED=0

# --- Slice toggle -----------------------------------------------------------
# When 0 (default), AgentDeps is wired with fakes — no keys required.
# Flip to 1 to swap in real OpenRouter / LanceDB / Tavily implementations.
USE_REAL=0

# --- App ---------------------------------------------------------------------
LOG_LEVEL=INFO
APP_ENV=dev
